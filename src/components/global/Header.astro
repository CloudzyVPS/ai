---
import type { Locale } from '@i18n/config';
import { t, getLocalizedPath } from '@i18n/utils';
import LocaleSwitcher from './LocaleSwitcher.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="fixed top-0 inset-x-0 z-50 transition-all duration-500" id="main-header">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-3 sm:py-4">
    <nav class="glass-heavy rounded-2xl px-5 py-3 flex items-center justify-between">
      <a href={getLocalizedPath(locale)} class="flex items-center gap-2.5 group">
        <img
          src={`${base}/images/brand/cloudzy-ai-icon.png`}
          alt="Cloudzy.AI"
          class="w-9 h-9 rounded-lg transition-transform group-hover:scale-110"
          width="36"
          height="36"
        />
        <span class="text-lg font-bold tracking-tight">
          Cloudzy<span class="text-accent-400">.AI</span>
        </span>
      </a>

      <div class="hidden md:flex items-center gap-6 lg:gap-8">
        <a href={`${getLocalizedPath(locale)}#services`} class="text-sm text-slate-400 hover:text-white transition-colors duration-200">
          {t(locale, 'nav.services')}
        </a>
        <a href={`${getLocalizedPath(locale)}#faq`} class="text-sm text-slate-400 hover:text-white transition-colors duration-200">
          {t(locale, 'nav.faq')}
        </a>
        <a href={getLocalizedPath(locale, '/contact')} class="text-sm text-slate-400 hover:text-white transition-colors duration-200">
          {t(locale, 'nav.contact')}
        </a>
        <LocaleSwitcher locale={locale} currentPath={Astro.url.pathname} />
        <a
          href={getLocalizedPath(locale, '/contact')}
          class="px-5 py-2.5 rounded-xl bg-gradient-to-r from-accent-500 to-glow-purple text-white text-sm font-semibold hover:shadow-lg hover:shadow-accent-500/25 transition-all duration-300 hover:-translate-y-0.5 active:scale-95"
        >
          {t(locale, 'hero.cta_primary')}
        </a>
      </div>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2.5 text-slate-400 hover:text-white transition-colors rounded-xl hover:bg-white/5"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile menu - heavy glass overlay -->
  <div id="mobile-menu" class="md:hidden fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true">
    <div class="absolute inset-0 bg-dark-950/95 backdrop-blur-3xl"></div>
    <div class="relative z-10 flex flex-col items-center justify-center h-full gap-10 px-8">
      <button id="mobile-close-btn" class="absolute top-6 end-6 p-3 text-slate-400 hover:text-white rounded-xl hover:bg-white/10 transition-colors">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <img
        src={`${base}/images/brand/cloudzy-ai-icon.png`}
        alt="Cloudzy.AI"
        class="w-16 h-16 rounded-2xl mb-4"
        width="64"
        height="64"
      />

      <a href={`${getLocalizedPath(locale)}#services`} class="text-3xl font-bold text-slate-200 hover:text-white transition-colors">{t(locale, 'nav.services')}</a>
      <a href={`${getLocalizedPath(locale)}#faq`} class="text-3xl font-bold text-slate-200 hover:text-white transition-colors">{t(locale, 'nav.faq')}</a>
      <a href={getLocalizedPath(locale, '/contact')} class="text-3xl font-bold text-slate-200 hover:text-white transition-colors">{t(locale, 'nav.contact')}</a>

      <div class="mt-4">
        <LocaleSwitcher locale={locale} currentPath={Astro.url.pathname} />
      </div>

      <a
        href={getLocalizedPath(locale, '/contact')}
        class="mt-6 px-10 py-4 rounded-2xl bg-gradient-to-r from-accent-500 to-glow-purple text-white text-xl font-bold hover:shadow-2xl hover:shadow-accent-500/30 transition-all"
      >
        {t(locale, 'hero.cta_primary')}
      </a>
    </div>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const close = document.getElementById('mobile-close-btn');

    btn?.addEventListener('click', () => {
      menu?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    });

    function closeMenu() {
      menu?.classList.add('hidden');
      document.body.style.overflow = '';
    }

    close?.addEventListener('click', closeMenu);
    menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

    const header = document.getElementById('main-header');
    window.addEventListener('scroll', () => {
      if (header) {
        if (window.scrollY > 60) {
          header.classList.add('backdrop-blur-md');
        } else {
          header.classList.remove('backdrop-blur-md');
        }
      }
    });
  });
</script>
