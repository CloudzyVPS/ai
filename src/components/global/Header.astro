---
import { locales, localeMetadata, type Locale } from '@i18n/config';
import { t, getLocalizedPath } from '@i18n/utils';
import LocaleSwitcher from './LocaleSwitcher.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function getPathForLocale(targetLocale: string): string {
  const base2 = import.meta.env.BASE_URL.replace(/\/$/, '');
  const pathWithoutBase = Astro.url.pathname.replace(new RegExp(`^${base2}`), '');
  const segments = pathWithoutBase.split('/').filter(Boolean);
  if (segments.length > 0 && locales.includes(segments[0] as Locale)) {
    segments[0] = targetLocale;
  } else {
    segments.unshift(targetLocale);
  }
  return `${base2}/${segments.join('/')}/`;
}
---

<header class="fixed top-0 inset-x-0 z-50 transition-all duration-500" id="main-header">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-3 sm:py-4">
    <nav class="glass rounded-2xl px-5 py-3 flex items-center justify-between">
      <a href={getLocalizedPath(locale)} class="group flex-shrink-0">
        <img
          src={`${base}/images/brand/cloudzy-ai-icon.png`}
          alt="Cloudzy.AI"
          class="w-9 h-9 rounded-lg transition-transform group-hover:scale-110"
          width="36"
          height="36"
        />
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-6 lg:gap-8">
        <a href={`${getLocalizedPath(locale)}#services`} class="text-sm text-slate-400 hover:text-white transition-colors duration-200">
          {t(locale, 'nav.services')}
        </a>
        <a href={`${getLocalizedPath(locale)}#faq`} class="text-sm text-slate-400 hover:text-white transition-colors duration-200">
          {t(locale, 'nav.faq')}
        </a>
        <a href={getLocalizedPath(locale, '/contact')} class="text-sm text-slate-400 hover:text-white transition-colors duration-200">
          {t(locale, 'nav.contact')}
        </a>
        <LocaleSwitcher locale={locale} currentPath={Astro.url.pathname} />
        <a
          href={getLocalizedPath(locale, '/contact')}
          class="px-5 py-2.5 rounded-xl bg-gradient-to-r from-accent-500 to-glow-purple text-white text-sm font-semibold hover:shadow-lg hover:shadow-accent-500/25 transition-all duration-300 hover:-translate-y-0.5 active:scale-95"
        >
          {t(locale, 'hero.cta_primary')}
        </a>
      </div>

      <!-- Hamburger button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2.5 text-slate-400 hover:text-white transition-colors rounded-xl hover:bg-white/5"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile menu overlay -->
  <div
    id="mobile-menu"
    class="md:hidden fixed inset-0 z-[100] opacity-0 invisible transition-all duration-300"
    role="dialog"
    aria-modal="true"
    aria-label="Navigation"
  >
    <!-- Backdrop -->
    <div id="mobile-backdrop" class="absolute inset-0 bg-dark-950/95 backdrop-blur-3xl"></div>

    <!-- Content panel -->
    <div
      id="mobile-menu-inner"
      class="relative z-10 flex flex-col h-full px-6 pt-5 pb-10 translate-y-3 opacity-0 transition-all duration-300"
    >
      <!-- Top bar -->
      <div class="flex items-center justify-between py-2 mb-6">
        <img
          src={`${base}/images/brand/cloudzy-ai-icon.png`}
          alt="Cloudzy.AI"
          class="w-10 h-10 rounded-xl"
          width="40"
          height="40"
        />
        <button
          id="mobile-close-btn"
          class="p-3 -me-1 text-slate-400 hover:text-white rounded-xl hover:bg-white/10 transition-colors"
          aria-label="Close menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Nav links — generous tap targets -->
      <div class="flex flex-col flex-1">
        <a
          href={`${getLocalizedPath(locale)}#services`}
          class="flex items-center py-5 text-2xl font-semibold text-slate-300 hover:text-white border-b border-white/[0.07] transition-colors active:text-accent-400"
        >
          {t(locale, 'nav.services')}
        </a>
        <a
          href={`${getLocalizedPath(locale)}#faq`}
          class="flex items-center py-5 text-2xl font-semibold text-slate-300 hover:text-white border-b border-white/[0.07] transition-colors active:text-accent-400"
        >
          {t(locale, 'nav.faq')}
        </a>
        <a
          href={getLocalizedPath(locale, '/contact')}
          class="flex items-center py-5 text-2xl font-semibold text-slate-300 hover:text-white border-b border-white/[0.07] transition-colors active:text-accent-400"
        >
          {t(locale, 'nav.contact')}
        </a>
      </div>

      <!-- Bottom: locale switcher + CTA -->
      <div class="flex flex-col gap-5 mt-8">
        <!-- Locale pills — horizontal scroll, no dropdown needed -->
        <div class="flex flex-wrap gap-2">
          {locales.map((loc) => {
            const meta = localeMetadata[loc];
            const isActive = loc === locale;
            return (
              <a
                href={getPathForLocale(loc)}
                class:list={[
                  'flex items-center gap-1.5 px-3 py-2 rounded-xl text-sm font-medium transition-all',
                  isActive
                    ? 'bg-accent-500/20 text-accent-400 border border-accent-500/30'
                    : 'text-slate-400 hover:text-white bg-white/5 hover:bg-white/10 border border-transparent',
                ]}
              >
                <span>{meta.flag}</span>
                <span>{meta.label}</span>
              </a>
            );
          })}
        </div>

        <a
          href={getLocalizedPath(locale, '/contact')}
          class="w-full text-center px-8 py-4 rounded-2xl bg-gradient-to-r from-accent-500 to-glow-purple text-white text-lg font-bold transition-all active:scale-[0.98] hover:shadow-xl hover:shadow-accent-500/25"
        >
          {t(locale, 'hero.cta_primary')}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const inner = document.getElementById('mobile-menu-inner');
    const backdrop = document.getElementById('mobile-backdrop');
    const close = document.getElementById('mobile-close-btn');

    function openMenu() {
      if (!menu || !inner || !btn) return;
      menu.classList.remove('opacity-0', 'invisible');
      menu.classList.add('opacity-100', 'visible');
      requestAnimationFrame(() => {
        inner.classList.remove('translate-y-3', 'opacity-0');
        inner.classList.add('translate-y-0', 'opacity-100');
      });
      btn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      if (!menu || !inner || !btn) return;
      inner.classList.add('translate-y-3', 'opacity-0');
      inner.classList.remove('translate-y-0', 'opacity-100');
      menu.classList.add('opacity-0', 'invisible');
      menu.classList.remove('opacity-100', 'visible');
      btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    btn?.addEventListener('click', openMenu);
    close?.addEventListener('click', closeMenu);
    backdrop?.addEventListener('click', closeMenu);
    menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && btn?.getAttribute('aria-expanded') === 'true') {
        closeMenu();
      }
    });

    const header = document.getElementById('main-header');
    window.addEventListener('scroll', () => {
      if (header) {
        header.classList.toggle('backdrop-blur-md', window.scrollY > 60);
      }
    }, { passive: true });
  });
</script>
