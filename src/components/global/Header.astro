---
import type { Locale } from '@i18n/config';
import { t, getLocalizedPath } from '@i18n/utils';
import LocaleSwitcher from './LocaleSwitcher.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<header class="fixed top-0 inset-x-0 z-50 transition-all duration-300" id="main-header">
  <div class="mx-auto max-w-7xl px-6 py-4">
    <nav class="glass rounded-2xl px-6 py-3 flex items-center justify-between">
      <a href={getLocalizedPath(locale)} class="flex items-center gap-2 group">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent-500 to-glow-purple flex items-center justify-center text-white font-bold text-sm transition-transform group-hover:scale-110">
          C
        </div>
        <span class="text-lg font-semibold tracking-tight">
          Cloudzy<span class="text-accent-400">.AI</span>
        </span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        <a href={`${getLocalizedPath(locale)}#services`} class="text-sm text-slate-400 hover:text-white transition-colors">
          {t(locale, 'nav.services')}
        </a>
        <a href={`${getLocalizedPath(locale)}#faq`} class="text-sm text-slate-400 hover:text-white transition-colors">
          {t(locale, 'nav.faq')}
        </a>
        <a href={getLocalizedPath(locale, '/contact')} class="text-sm text-slate-400 hover:text-white transition-colors">
          {t(locale, 'nav.contact')}
        </a>
        <LocaleSwitcher locale={locale} currentPath={Astro.url.pathname} />
        <a
          href={getLocalizedPath(locale, '/contact')}
          class="px-5 py-2 rounded-xl bg-gradient-to-r from-accent-500 to-glow-purple text-white text-sm font-medium hover:shadow-lg hover:shadow-accent-500/25 transition-all hover:-translate-y-0.5"
        >
          {t(locale, 'hero.cta_primary')}
        </a>
      </div>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-slate-400 hover:text-white transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>
  </div>

  <div id="mobile-menu" class="md:hidden hidden fixed inset-0 top-0 z-50 bg-dark-950/95 backdrop-blur-xl">
    <div class="flex flex-col items-center justify-center h-full gap-8">
      <button id="mobile-close-btn" class="absolute top-6 end-6 p-2 text-slate-400 hover:text-white">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <a href={`${getLocalizedPath(locale)}#services`} class="text-2xl text-slate-300 hover:text-white transition-colors">{t(locale, 'nav.services')}</a>
      <a href={`${getLocalizedPath(locale)}#faq`} class="text-2xl text-slate-300 hover:text-white transition-colors">{t(locale, 'nav.faq')}</a>
      <a href={getLocalizedPath(locale, '/contact')} class="text-2xl text-slate-300 hover:text-white transition-colors">{t(locale, 'nav.contact')}</a>
      <LocaleSwitcher locale={locale} currentPath={Astro.url.pathname} />
      <a
        href={getLocalizedPath(locale, '/contact')}
        class="mt-4 px-8 py-3 rounded-xl bg-gradient-to-r from-accent-500 to-glow-purple text-white font-medium"
      >
        {t(locale, 'hero.cta_primary')}
      </a>
    </div>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const close = document.getElementById('mobile-close-btn');

    btn?.addEventListener('click', () => menu?.classList.remove('hidden'));
    close?.addEventListener('click', () => menu?.classList.add('hidden'));
    menu?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => menu?.classList.add('hidden'));
    });

    const header = document.getElementById('main-header');
    let lastScroll = 0;
    window.addEventListener('scroll', () => {
      const current = window.scrollY;
      if (header) {
        if (current > 100) {
          header.classList.add('backdrop-blur-md');
        } else {
          header.classList.remove('backdrop-blur-md');
        }
      }
      lastScroll = current;
    });
  });
</script>
