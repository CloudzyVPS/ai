---
import type { Locale } from '@i18n/config';
import { t, getLocalizedPath } from '@i18n/utils';
import { execSync } from 'node:child_process';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Short commit hash, resolved once at build time. Prefer git; fall back to the
// CI-provided SHA (e.g. shallow checkouts where git metadata is limited).
const commitHash = (() => {
  try {
    return execSync('git rev-parse --short HEAD', { encoding: 'utf8' }).trim();
  } catch {
    return (import.meta.env.GITHUB_SHA ?? process.env.GITHUB_SHA ?? '').slice(0, 7);
  }
})();
---

<footer class="border-t border-border mt-0">
  <div class="mx-auto max-w-7xl px-6 py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
      <div>
        <a href={getLocalizedPath(locale)} class="flex items-center gap-3 mb-6">
          <img
            src={`${base}/images/brand/cloudzy-ai-icon.png`}
            alt="Cloudzy.AI"
            class="w-10 h-10 rounded-xl"
            width="40"
            height="40"
          />
          <span class="text-xl font-bold tracking-tight">
            Cloudzy<span class="text-accent-400">.AI</span>
          </span>
        </a>
        <p class="text-sm text-slate-500 leading-relaxed max-w-xs">
          {t(locale, 'footer.description')}
        </p>
      </div>

      <div>
        <h4 class="text-sm font-bold text-white uppercase tracking-widest mb-6">{t(locale, 'footer.quick_links')}</h4>
        <nav class="flex flex-col gap-4">
          <a href={getLocalizedPath(locale)} class="text-sm text-slate-500 hover:text-accent-400 transition-colors duration-200">{t(locale, 'nav.home')}</a>
          <a href={`${getLocalizedPath(locale)}#services`} class="text-sm text-slate-500 hover:text-accent-400 transition-colors duration-200">{t(locale, 'nav.services')}</a>
          <a href={`${getLocalizedPath(locale)}#faq`} class="text-sm text-slate-500 hover:text-accent-400 transition-colors duration-200">{t(locale, 'nav.faq')}</a>
          <a href={getLocalizedPath(locale, '/contact')} class="text-sm text-slate-500 hover:text-accent-400 transition-colors duration-200">{t(locale, 'nav.contact')}</a>
        </nav>
      </div>

      <div>
        <h4 class="text-sm font-bold text-white uppercase tracking-widest mb-6">{t(locale, 'contact.company_name')}</h4>
        <div class="flex flex-col gap-4 text-sm text-slate-500">
          <p>{t(locale, 'contact.address')}</p>
          <a href="tel:+971581910073" class="hover:text-accent-400 transition-colors duration-200">{t(locale, 'contact.phone')}</a>
        </div>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-slate-600">{t(locale, 'footer.copyright')}</p>
      <p class="text-xs text-slate-600">
        {commitHash && (
          <>
            <span class="font-mono text-slate-500" title="Build commit">{commitHash}</span>
            <span class="mx-2 text-slate-700">·</span>
          </>
        )}
        {t(locale, 'footer.powered_by')} — <a href="https://cloudzy.com" class="hover:text-accent-400 transition-colors" target="_blank" rel="noopener">Cloudzy.com</a>
      </p>
    </div>
  </div>
</footer>
