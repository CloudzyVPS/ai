---
import { locales, localeMetadata, type Locale } from '@i18n/config';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function getPathForLocale(targetLocale: string): string {
  const pathWithoutBase = currentPath.replace(new RegExp(`^${base}`), '');
  const segments = pathWithoutBase.split('/').filter(Boolean);
  if (segments.length > 0 && locales.includes(segments[0] as Locale)) {
    segments[0] = targetLocale;
  } else {
    segments.unshift(targetLocale);
  }
  return `${base}/${segments.join('/')}/`;
}

const current = localeMetadata[locale];
---

<div class="relative group">
  <button
    class="flex items-center gap-2 text-sm text-slate-400 hover:text-white transition-colors px-3 py-1.5 rounded-lg hover:bg-white/5"
    aria-label="Change language"
  >
    <span>{current.flag}</span>
    <span class="hidden sm:inline">{current.label}</span>
    <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
  <div class="absolute top-full end-0 mt-2 py-2 glass rounded-xl min-w-[200px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-2 group-hover:translate-y-0">
    {locales.map((loc) => {
      const meta = localeMetadata[loc];
      const isActive = loc === locale;
      return (
        <a
          href={getPathForLocale(loc)}
          class:list={[
            'flex items-center gap-3 px-4 py-2.5 text-sm transition-colors',
            isActive ? 'text-accent-400 bg-white/5' : 'text-slate-400 hover:text-white hover:bg-white/5',
          ]}
        >
          <span>{meta.flag}</span>
          <span>{meta.label}</span>
          <span class="ms-auto text-xs text-slate-600">{meta.region}</span>
        </a>
      );
    })}
  </div>
</div>
