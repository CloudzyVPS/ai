---
import type { Locale } from '@i18n/config';
import { t } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const locations = [
  { city: 'Ogden', country: 'US', flag: '\u{1F1FA}\u{1F1F8}' },
  { city: 'Dallas', country: 'US', flag: '\u{1F1FA}\u{1F1F8}' },
  { city: 'Los Angeles', country: 'US', flag: '\u{1F1FA}\u{1F1F8}' },
  { city: 'New York', country: 'US', flag: '\u{1F1FA}\u{1F1F8}' },
  { city: 'Miami', country: 'US', flag: '\u{1F1FA}\u{1F1F8}' },
  { city: 'Las Vegas', country: 'US', flag: '\u{1F1FA}\u{1F1F8}' },
  { city: 'London', country: 'UK', flag: '\u{1F1EC}\u{1F1E7}' },
  { city: 'Amsterdam', country: 'NL', flag: '\u{1F1F3}\u{1F1F1}' },
  { city: 'Frankfurt', country: 'DE', flag: '\u{1F1E9}\u{1F1EA}' },
  { city: 'Bern', country: 'CH', flag: '\u{1F1E8}\u{1F1ED}' },
  { city: 'Dubai', country: 'AE', flag: '\u{1F1E6}\u{1F1EA}' },
  { city: 'Singapore', country: 'SG', flag: '\u{1F1F8}\u{1F1EC}' },
  { city: 'Sydney', country: 'AU', flag: '\u{1F1E6}\u{1F1FA}' },
];
---

<section class="pt-36 sm:pt-44 pb-20 relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-[20%] end-[20%] w-[500px] h-[500px] bg-glow-purple/15 rounded-full blur-[160px]"></div>
    <div class="absolute bottom-[20%] start-[20%] w-[450px] h-[450px] bg-glow-cyan/10 rounded-full blur-[140px]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-6 relative z-10">
    <div class="text-center mb-12 reveal">
      <img
        src={`${base}/images/brand/cloudzy-ai-logo.png`}
        alt="Cloudzy.AI"
        class="h-40 w-auto mx-auto mb-10 opacity-90"
        height="160"
      />
      <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold tracking-tighter leading-[0.95] mb-6">
        <span class="text-gradient">{t(locale, 'contact.page_title')}</span>
      </h1>
      <p class="text-xl sm:text-2xl text-slate-400 max-w-2xl mx-auto font-light">
        {t(locale, 'contact.page_subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 reveal-stagger">
      <!-- Company Info Card -->
      <div class="glass glow-card rounded-3xl p-8 sm:p-10 space-y-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-white tracking-tight">{t(locale, 'contact.company_name')}</h2>

        <div class="space-y-6">
          <div class="flex items-start gap-5">
            <div class="shrink-0 w-12 h-12 rounded-2xl bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center shadow-lg">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-slate-500 mb-1 font-medium">{t(locale, 'contact.register_label')}</p>
              <p class="text-lg text-white font-semibold">{t(locale, 'contact.register_no')}</p>
            </div>
          </div>

          <div class="flex items-start gap-5">
            <div class="shrink-0 w-12 h-12 rounded-2xl bg-gradient-to-br from-violet-500 to-fuchsia-500 flex items-center justify-center shadow-lg">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-slate-500 mb-1 font-medium">{t(locale, 'contact.address_label')}</p>
              <p class="text-lg text-white">{t(locale, 'contact.address')}</p>
            </div>
          </div>

          <div class="flex items-start gap-5">
            <div class="shrink-0 w-12 h-12 rounded-2xl bg-gradient-to-br from-emerald-500 to-green-400 flex items-center justify-center shadow-lg">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-slate-500 mb-1 font-medium">{t(locale, 'contact.phone_label')}</p>
              <a href="tel:+971581910073" class="text-lg text-white hover:text-accent-400 transition-colors">{t(locale, 'contact.phone')}</a>
            </div>
          </div>
        </div>

        <div class="pt-6 border-t border-border">
          <p class="text-sm text-slate-500 mb-4 font-medium">{t(locale, 'contact.services_label')}</p>
          <div class="flex flex-wrap gap-2">
            {['Public Cloud', 'Private Cloud', 'DevOps', 'Data Center', 'MLOps'].map(s => (
              <span class="px-4 py-2 rounded-xl bg-white/5 text-sm text-slate-300 border border-border font-medium">{s}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Data Center Locations Card -->
      <div class="glass glow-card rounded-3xl p-8 sm:p-10">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl sm:text-3xl font-bold text-white tracking-tight">Global Data Centers</h2>
          <a
            href="https://status.cloudzy.com"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-green-500/10 border border-green-500/20 text-xs font-semibold text-green-400 hover:bg-green-500/20 hover:border-green-500/40 transition-all duration-200"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
            System Status
          </a>
        </div>
        <div class="grid grid-cols-2 gap-3">
          {locations.map(loc => (
            <div class="flex items-center gap-3 p-3.5 rounded-xl hover:bg-white/5 transition-all duration-300 group">
              <span class="text-xl">{loc.flag}</span>
              <div>
                <p class="text-sm font-semibold text-white group-hover:text-accent-400 transition-colors">{loc.city}</p>
                <p class="text-xs text-slate-500">{loc.country}</p>
              </div>
              <div class="ms-auto w-2.5 h-2.5 rounded-full bg-green-400 shadow-sm shadow-green-400/50"></div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Contact Form Card -->
    <div class="glass glow-card rounded-3xl p-8 sm:p-10 mt-8 reveal">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">
        <div class="lg:col-span-2 space-y-4">
          <h2 class="text-2xl sm:text-3xl font-bold text-white tracking-tight">{t(locale, 'contact.form_title')}</h2>
          <p class="text-slate-400 leading-relaxed">{t(locale, 'contact.form_subtitle')}</p>
        </div>

        <div class="lg:col-span-3">
          <form id="contact-form" class="space-y-5" novalidate>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="cf-name" class="block text-sm font-medium text-slate-400 mb-2">{t(locale, 'contact.form_name_label')}</label>
                <input
                  id="cf-name" name="name" type="text" required autocomplete="name"
                  placeholder={t(locale, 'contact.form_name_placeholder')}
                  class="w-full rounded-xl bg-white/5 border border-border text-white placeholder:text-slate-600 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all"
                />
              </div>
              <div>
                <label for="cf-email" class="block text-sm font-medium text-slate-400 mb-2">{t(locale, 'contact.form_email_label')}</label>
                <input
                  id="cf-email" name="email" type="email" required autocomplete="email"
                  placeholder={t(locale, 'contact.form_email_placeholder')}
                  class="w-full rounded-xl bg-white/5 border border-border text-white placeholder:text-slate-600 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all"
                />
              </div>
            </div>

            <div>
              <label for="cf-subject" class="block text-sm font-medium text-slate-400 mb-2">{t(locale, 'contact.form_subject_label')}</label>
              <input
                id="cf-subject" name="subject" type="text" required
                placeholder={t(locale, 'contact.form_subject_placeholder')}
                class="w-full rounded-xl bg-white/5 border border-border text-white placeholder:text-slate-600 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all"
              />
            </div>

            <div>
              <label for="cf-message" class="block text-sm font-medium text-slate-400 mb-2">{t(locale, 'contact.form_message_label')}</label>
              <textarea
                id="cf-message" name="message" required rows="5"
                placeholder={t(locale, 'contact.form_message_placeholder')}
                class="w-full rounded-xl bg-white/5 border border-border text-white placeholder:text-slate-600 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all resize-none"
              ></textarea>
            </div>

            <div id="form-success" class="hidden">
              <div class="flex items-start gap-3 p-4 rounded-xl bg-green-500/10 border border-green-500/20 text-green-400">
                <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <p class="font-semibold text-sm">{t(locale, 'contact.form_success_title')}</p>
                  <p class="text-xs text-green-400/80 mt-0.5">{t(locale, 'contact.form_success_message')}</p>
                </div>
              </div>
            </div>

            <div id="form-error" class="hidden">
              <div class="flex items-start gap-3 p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400">
                <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
                </svg>
                <div>
                  <p class="font-semibold text-sm">{t(locale, 'contact.form_error_title')}</p>
                  <p class="text-xs text-red-400/80 mt-0.5" id="form-error-detail">{t(locale, 'contact.form_error_message')}</p>
                </div>
              </div>
            </div>

            <button
              type="submit" id="form-submit"
              class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-gradient-to-r from-violet-600 to-indigo-600 text-white font-semibold text-sm hover:from-violet-500 hover:to-indigo-500 transition-all duration-300 shadow-lg shadow-violet-500/25 hover:shadow-violet-500/40 hover:scale-[1.02] active:scale-[0.98] disabled:opacity-60 disabled:cursor-not-allowed disabled:scale-100 disabled:hover:shadow-violet-500/25"
            >
              <svg id="submit-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
              <svg id="submit-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
              </svg>
              <span id="submit-label">{t(locale, 'contact.form_submit')}</span>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    const btn = document.getElementById('form-submit') as HTMLButtonElement;
    const label = document.getElementById('submit-label') as HTMLElement;
    const spinner = document.getElementById('submit-spinner') as HTMLElement;
    const icon = document.getElementById('submit-icon') as HTMLElement;
    const successBox = document.getElementById('form-success') as HTMLElement;
    const errorBox = document.getElementById('form-error') as HTMLElement;

    const apiUrl = import.meta.env.BASE_URL.replace(/\/$/, '') + '/api/contact';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form).entries());

      btn.disabled = true;
      spinner.classList.remove('hidden');
      icon.classList.add('hidden');
      successBox.classList.add('hidden');
      errorBox.classList.add('hidden');
      label.textContent = label.dataset.sending ?? label.textContent;

      try {
        const res = await fetch(apiUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          successBox.classList.remove('hidden');
          form.reset();
        } else {
          errorBox.classList.remove('hidden');
        }
      } catch {
        errorBox.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        spinner.classList.add('hidden');
        icon.classList.remove('hidden');
        label.textContent = label.dataset.default ?? label.textContent;
      }
    });
  }
</script>
