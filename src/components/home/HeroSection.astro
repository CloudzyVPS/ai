---
import type { Locale } from '@i18n/config';
import { t, getLocalizedPath } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="relative min-h-[100dvh] flex items-center overflow-hidden">
  <!-- Full-bleed background image (jumbotron) -->
  <div class="absolute inset-0">
    <img
      src={`${base}/images/hero/header-bg.jpg`}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-dark-950/75"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-dark-950/50 via-transparent to-dark-950"></div>
  </div>

  <!-- Glow orbs over background -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-[10%] start-[15%] w-[500px] h-[500px] bg-glow-purple/15 rounded-full blur-[160px]"></div>
    <div class="absolute top-[20%] end-[10%] w-[450px] h-[450px] bg-glow-blue/10 rounded-full blur-[140px]"></div>
    <div class="absolute bottom-[20%] start-[40%] w-[400px] h-[400px] bg-glow-cyan/10 rounded-full blur-[130px]"></div>
  </div>

  <!-- Dot grid pattern -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.03]" aria-hidden="true">
    <svg width="100%" height="100%">
      <defs>
        <pattern id="hero-grid" width="50" height="50" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="white" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-grid)" />
    </svg>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl px-6 pt-36 sm:pt-44 pb-24 sm:pb-32 text-center w-full">
    <!-- Logo badge -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full glass-heavy">
        <img
          src={`${base}/images/brand/cloudzy-ai-icon.png`}
          alt=""
          class="w-6 h-6 rounded"
          width="24"
          height="24"
        />
        <span class="text-sm text-slate-300 font-medium">13 Global Data Centers</span>
        <span class="w-2 h-2 rounded-full bg-green-400"></span>
      </div>
    </div>

    <!-- Massive headline -->
    <h1
      class="text-[3.5rem] sm:text-[4.5rem] md:text-[6rem] lg:text-[7.5rem] xl:text-[9rem] font-extrabold tracking-tighter leading-[0.9] mb-8"
    >
      <span class="block text-white drop-shadow-[0_4px_30px_rgba(0,0,0,0.5)]">{t(locale, 'hero.title').split(' ').slice(0, -2).join(' ')}</span>
      <span class="block text-gradient-vivid drop-shadow-[0_4px_30px_rgba(59,130,246,0.3)]">{t(locale, 'hero.title').split(' ').slice(-2).join(' ')}</span>
    </h1>

    <!-- Subtitle -->
    <p
      class="text-lg sm:text-xl md:text-2xl text-slate-300 max-w-3xl mx-auto mb-14 leading-relaxed font-light drop-shadow-[0_2px_10px_rgba(0,0,0,0.5)]"
    >
      {t(locale, 'hero.subtitle')}
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-5">
      <a
        href={getLocalizedPath(locale, '/contact')}
        class="group relative px-10 py-5 rounded-2xl bg-gradient-to-r from-accent-500 via-glow-purple to-accent-600 text-white font-bold text-lg overflow-hidden transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_20px_60px_-15px_rgba(59,130,246,0.5)] active:scale-95"
      >
        <span class="relative z-10 flex items-center gap-2">
          {t(locale, 'hero.cta_primary')}
          <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </span>
        <div class="absolute inset-0 bg-gradient-to-r from-accent-600 via-glow-purple to-glow-cyan opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </a>
      <a
        href={`${getLocalizedPath(locale)}#services`}
        class="px-10 py-5 rounded-2xl glass-heavy text-slate-200 font-bold text-lg hover:text-white transition-all duration-300 hover:-translate-y-1 hover:bg-white/[0.12]"
      >
        {t(locale, 'hero.cta_secondary')}
      </a>
    </div>

  </div>

  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 inset-x-0 h-48 bg-gradient-to-t from-dark-950 to-transparent pointer-events-none"></div>
</section>
