---
import type { Locale } from '@i18n/config';
import { t, getLocalizedPath } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="relative min-h-[100dvh] flex items-center justify-center overflow-hidden pt-28 pb-20">
  <!-- Animated glow orbs - larger & more dramatic -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-[10%] start-[15%] w-[500px] h-[500px] bg-glow-purple/25 rounded-full blur-[160px] animate-float" style="animation-delay: 0s; animation-duration: 10s;"></div>
    <div class="absolute top-[20%] end-[10%] w-[450px] h-[450px] bg-glow-blue/20 rounded-full blur-[140px] animate-float" style="animation-delay: -3s; animation-duration: 12s;"></div>
    <div class="absolute bottom-[15%] start-[40%] w-[400px] h-[400px] bg-glow-cyan/15 rounded-full blur-[130px] animate-float-slow" style="animation-delay: -5s;"></div>
    <div class="absolute top-[50%] end-[30%] w-[300px] h-[300px] bg-accent-500/10 rounded-full blur-[120px] animate-float" style="animation-delay: -7s; animation-duration: 14s;"></div>
  </div>

  <!-- Dot grid pattern with parallax -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.04]" aria-hidden="true" data-animate="parallax" data-speed="0.1">
    <svg width="100%" height="100%">
      <defs>
        <pattern id="hero-grid" width="50" height="50" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="white" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-grid)" />
    </svg>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl px-6 text-center">
    <!-- Logo badge -->
    <div data-animate="fade-up" class="mb-10">
      <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full glass animate-border-glow">
        <img
          src={`${base}/images/brand/cloudzy-ai-icon.png`}
          alt=""
          class="w-6 h-6 rounded"
          width="24"
          height="24"
        />
        <span class="text-sm text-slate-300 font-medium">13 Global Data Centers</span>
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
      </div>
    </div>

    <!-- Massive headline -->
    <h1
      class="text-[3.5rem] sm:text-[4.5rem] md:text-[6rem] lg:text-[7.5rem] xl:text-[9rem] font-extrabold tracking-tighter leading-[0.9] mb-8"
      data-animate="fade-up"
    >
      <span class="block text-white">{t(locale, 'hero.title').split(' ').slice(0, -2).join(' ')}</span>
      <span class="block text-gradient-vivid">{t(locale, 'hero.title').split(' ').slice(-2).join(' ')}</span>
    </h1>

    <!-- Subtitle -->
    <p
      class="text-lg sm:text-xl md:text-2xl text-slate-400 max-w-3xl mx-auto mb-14 leading-relaxed font-light"
      data-animate="fade-up"
    >
      {t(locale, 'hero.subtitle')}
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-animate="fade-up">
      <a
        href={getLocalizedPath(locale, '/contact')}
        class="group relative px-10 py-5 rounded-2xl bg-gradient-to-r from-accent-500 via-glow-purple to-accent-600 text-white font-bold text-lg overflow-hidden transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_20px_60px_-15px_rgba(59,130,246,0.5)] active:scale-95"
      >
        <span class="relative z-10 flex items-center gap-2">
          {t(locale, 'hero.cta_primary')}
          <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </span>
        <div class="absolute inset-0 bg-gradient-to-r from-accent-600 via-glow-purple to-glow-cyan opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </a>
      <a
        href={`${getLocalizedPath(locale)}#services`}
        class="px-10 py-5 rounded-2xl glass text-slate-300 font-bold text-lg hover:text-white transition-all duration-300 hover:-translate-y-1 hover:bg-white/[0.06]"
      >
        {t(locale, 'hero.cta_secondary')}
      </a>
    </div>

    <!-- Hero image with glow -->
    <div class="mt-20 relative" data-animate="scale-in">
      <div class="absolute -inset-4 bg-gradient-to-r from-accent-500/20 via-glow-purple/20 to-glow-cyan/20 rounded-3xl blur-2xl opacity-60"></div>
      <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-dark-950/80">
        <img
          src={`${base}/images/hero/cloud-infrastructure.jpg`}
          alt="Cloudzy.AI Cloud Infrastructure"
          class="w-full h-auto object-cover"
          width="1024"
          height="682"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-dark-950 via-dark-950/20 to-transparent"></div>
        <div class="absolute bottom-6 start-6 end-6">
          <img
            src={`${base}/images/brand/cloudzy-ai-logo.png`}
            alt="Cloudzy.AI"
            class="h-10 sm:h-12 w-auto opacity-80"
            height="48"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 inset-x-0 h-48 bg-gradient-to-t from-dark-950 to-transparent pointer-events-none"></div>
</section>
