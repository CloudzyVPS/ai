---
import type { Locale } from '@i18n/config';
import { t } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const metrics = [
  { key: 'vms', value: t(locale, 'metrics.vms.value'), suffix: t(locale, 'metrics.vms.suffix'), label: t(locale, 'metrics.vms.label') },
  { key: 'satisfaction', value: t(locale, 'metrics.satisfaction.value'), suffix: t(locale, 'metrics.satisfaction.suffix'), label: t(locale, 'metrics.satisfaction.label') },
  { key: 'users', value: t(locale, 'metrics.users.value'), suffix: t(locale, 'metrics.users.suffix'), label: t(locale, 'metrics.users.label') },
];
---

<section class="py-32 sm:py-40 relative">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/2 start-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-accent-500/5 rounded-full blur-[200px]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-6 relative z-10">
    <div class="text-center mb-20" data-animate="fade-up">
      <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight">
        <span class="text-gradient">{t(locale, 'metrics.heading')}</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12" data-animate="fade-up-stagger">
      {metrics.map(({ value, suffix, label }, i) => (
        <div class="text-center p-8 sm:p-12 relative">
          {i > 0 && (
            <div class="hidden md:block absolute top-1/2 start-0 -translate-y-1/2 w-px h-24 bg-gradient-to-b from-transparent via-border to-transparent"></div>
          )}
          <div class="text-7xl sm:text-8xl md:text-[7rem] lg:text-[8.5rem] font-extrabold tracking-tighter leading-none mb-4">
            <span class="text-shimmer" data-animate="counter" data-value={value} data-suffix={suffix}>0{suffix}</span>
          </div>
          <p class="text-slate-400 text-lg sm:text-xl font-medium">{label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
