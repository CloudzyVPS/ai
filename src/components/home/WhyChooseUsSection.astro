---
import type { Locale } from '@i18n/config';
import { t, tArray } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const items = tArray(locale, 'why_us.items');

const icons = [
  'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  'M13 10V3L4 14h7v7l9-11h-7z',
  'M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z',
  'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
];

const gradients = [
  'from-amber-500 to-orange-400',
  'from-blue-500 to-cyan-400',
  'from-violet-500 to-fuchsia-400',
  'from-emerald-500 to-green-400',
];
---

<section class="py-16 sm:py-24 relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 end-0 w-[500px] h-[500px] bg-glow-purple/10 rounded-full blur-[180px] glow-breathe-2"></div>
    <div class="absolute bottom-0 start-0 w-[500px] h-[500px] bg-glow-cyan/10 rounded-full blur-[180px] glow-breathe-3"></div>
  </div>

  <div class="mx-auto max-w-7xl px-6 relative z-10">
    <div class="text-center mb-12 reveal">
      <p class="text-sm font-semibold text-accent-400 uppercase tracking-[0.2em] mb-4">Why Us</p>
      <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.05] mb-6">
        <span class="text-gradient">{t(locale, 'why_us.heading')}</span>
      </h2>
      <p class="text-xl sm:text-2xl text-slate-400 max-w-2xl mx-auto font-light">
        {t(locale, 'why_us.subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 reveal-stagger">
      {items.map((item, i) => (
        <div class="group glass glow-card rounded-3xl p-8 sm:p-10 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-accent-500/5">
          <div class="flex items-start gap-6">
            <div class={`shrink-0 w-14 h-14 rounded-2xl bg-gradient-to-br ${gradients[i]} flex items-center justify-center transition-all duration-500 group-hover:scale-110 group-hover:rotate-6 shadow-lg`}>
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={icons[i]} />
              </svg>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-white mb-3 tracking-tight">{item.title}</h3>
              <p class="text-base text-slate-400 leading-relaxed">{item.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
