---
import type { Locale } from '@i18n/config';
import { t } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const partners = [
  { name: 'Sig Dept MIE', file: 'sig-dept-mie.svg' },
  { name: 'UTFR', file: 'utfr.png' },
  { name: 'Ignyte', file: 'ignyte.png' },
  { name: 'Aurologic', file: 'aurologic.png' },
  { name: 'Apex', file: 'apex.png' },
  { name: 'Zare', file: 'zare.png' },
  { name: 'Webheads', file: 'webheads.png' },
];
---

<section class="py-24 relative overflow-hidden" data-animate="fade-up">
  <div class="mx-auto max-w-7xl px-6 mb-12">
    <p class="text-center text-sm text-slate-500 uppercase tracking-[0.2em] font-semibold">
      {t(locale, 'trusted_by.heading')}
    </p>
  </div>

  <div class="relative">
    <div class="absolute inset-y-0 start-0 w-40 bg-gradient-to-e from-dark-950 to-transparent z-10 pointer-events-none"></div>
    <div class="absolute inset-y-0 end-0 w-40 bg-gradient-to-s from-dark-950 to-transparent z-10 pointer-events-none"></div>

    <div class="flex overflow-hidden" aria-hidden="true">
      <div class="flex shrink-0 items-center gap-20 animate-marquee hover:[animation-play-state:paused]">
        {[...partners, ...partners].map(({ name, file }) => (
          <div class="flex items-center justify-center px-6 py-3">
            <img
              src={`${base}/images/logos/trusted/${file}`}
              alt={name}
              class="h-8 sm:h-10 w-auto partner-logo max-w-[160px] object-contain"
              loading="lazy"
            />
          </div>
        ))}
      </div>
      <div class="flex shrink-0 items-center gap-20 animate-marquee hover:[animation-play-state:paused]" aria-hidden="true">
        {[...partners, ...partners].map(({ name, file }) => (
          <div class="flex items-center justify-center px-6 py-3">
            <img
              src={`${base}/images/logos/trusted/${file}`}
              alt={name}
              class="h-8 sm:h-10 w-auto partner-logo max-w-[160px] object-contain"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
