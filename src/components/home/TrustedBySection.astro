---
import type { Locale } from '@i18n/config';
import { t } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const partners = [
  { name: 'Sig Dept MIE', file: 'sig-dept-mie.svg' },
  { name: 'UTFR', file: 'utfr.png' },
  { name: 'Ignyte', file: 'ignyte.png' },
  { name: 'Aurologic', file: 'aurologic.png' },
  { name: 'Apex', file: 'apex.png' },
  { name: 'Zare', file: 'zare.png' },
  { name: 'Webheads', file: 'webheads.png' },
];
---

<section class="py-12 sm:py-16 relative overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 mb-12">
    <p class="text-center text-sm text-slate-500 uppercase tracking-[0.2em] font-semibold">
      {t(locale, 'trusted_by.heading')}
    </p>
  </div>

  <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-6 px-6">
    {partners.map(({ name, file }) => (
      <div class="flex items-center justify-center py-2">
        <img
          src={`${base}/images/logos/trusted/${file}`}
          alt={name}
          class="h-8 sm:h-10 w-auto partner-logo max-w-[140px] object-contain"
          loading="lazy"
        />
      </div>
    ))}
  </div>
</section>
