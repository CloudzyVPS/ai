---
import type { Locale } from '@i18n/config';
import { t, getLocalizedPath } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section class="py-32 relative">
  <div class="mx-auto max-w-7xl px-6">
    <div class="relative rounded-3xl overflow-hidden" data-animate="scale-in">
      <!-- Animated gradient background -->
      <div class="absolute inset-0 bg-gradient-to-br from-accent-600 via-glow-purple to-glow-cyan animate-gradient opacity-90"></div>
      <div class="absolute inset-0 bg-dark-950/40"></div>

      <!-- Grid overlay -->
      <div class="absolute inset-0 opacity-10" aria-hidden="true">
        <svg width="100%" height="100%">
          <defs>
            <pattern id="cta-grid" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5" />
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#cta-grid)" />
        </svg>
      </div>

      <div class="relative z-10 py-20 px-8 sm:px-16 text-center">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
          {t(locale, 'cta.heading')}
        </h2>
        <p class="text-lg text-white/80 mb-10 max-w-xl mx-auto">
          {t(locale, 'cta.subtitle')}
        </p>
        <a
          href={getLocalizedPath(locale, '/contact')}
          class="inline-flex items-center gap-2 px-10 py-4 rounded-2xl bg-white text-dark-950 font-semibold text-lg hover:bg-slate-100 transition-all hover:-translate-y-1 hover:shadow-2xl"
        >
          {t(locale, 'cta.button')}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
