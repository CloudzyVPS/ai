---
import { ClientRouter } from 'astro:transitions';
import { localeMetadata, type Locale } from '@i18n/config';
import '@styles/global.css';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title, description } = Astro.props;
const meta = localeMetadata[locale];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang={meta.htmlLang} dir={meta.dir} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title ?? 'Cloudzy.AI'}</title>
    <meta name="description" content={description ?? ''} />
    <link rel="icon" type="image/png" href={`${base}/favicon.png`} />

    <link rel="preload" href={`${base}/fonts/plus-jakarta-sans-variable.woff2`} as="font" type="font/woff2" crossorigin />
    {meta.dir === 'rtl' && (
      <link rel="preload" href={`${base}/fonts/noto-naskh-arabic.woff2`} as="font" type="font/woff2" crossorigin />
    )}

    {Object.entries(localeMetadata).map(([loc, m]) => (
      <link rel="alternate" hreflang={m.htmlLang} href={`${Astro.site}ai/${loc}/`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${Astro.site}ai/en_us/`} />

    <ClientRouter />
  </head>
  <body class="min-h-screen bg-dark-950 text-slate-200 font-sans antialiased overflow-x-hidden">
    <slot />

    <script>
      function initReveal() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const io = new IntersectionObserver(
          (entries) => entries.forEach(e => {
            if (e.isIntersecting) { e.target.classList.add('in-view'); io.unobserve(e.target); }
          }),
          { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
        );
        document.querySelectorAll('.reveal, .reveal-stagger').forEach(el => io.observe(el));
      }
      document.addEventListener('astro:page-load', initReveal);
    </script>
  </body>
</html>
